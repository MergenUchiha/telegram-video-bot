# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_SECRET=change_me_to_random_string
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://renderer:renderer_secret@localhost:5432/renderer
POSTGRES_DB=renderer
POSTGRES_USER=renderer
POSTGRES_PASSWORD=renderer_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=0

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=renderer
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRES_SECONDS=1800

# ── Kokoro TTS ────────────────────────────────────────────────────────────────
KOKORO_BASE_URL=http://localhost:8880
KOKORO_API_PATH=/v1/audio/speech
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_heart
KOKORO_RESPONSE_FORMAT=wav
KOKORO_TIMEOUT_MS=120000

# ── Render worker ─────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Linux: /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# или установи: apt-get install fonts-dejavu-core
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
DEFAULT_DUCK_DB=-18
RENDER_TIMEOUT_MS=1200000
RENDER_TMP_DIR=/tmp/renderer

# ── Автоочистка (CleanupService) ──────────────────────────────────────────────
TMP_CLEANUP_AGE_HOURS=2
INPUT_LIFECYCLE_DAYS=3
OUTPUT_LIFECYCLE_DAYS=7

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Обычные команды/кнопки
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SEC=60
# Загрузка видео
RATE_LIMIT_UPLOAD_MAX=5
RATE_LIMIT_UPLOAD_WINDOW_SEC=3600
# Рендер
RATE_LIMIT_RENDER_MAX=10
RATE_LIMIT_RENDER_WINDOW_SEC=86400

# ── Метрики ───────────────────────────────────────────────────────────────────
METRICS_TOKEN=change_me_to_random_string

# ── BullMQ ────────────────────────────────────────────────────────────────────
BULLMQ_PREFIX=tvb

# ── Redis lock TTL ────────────────────────────────────────────────────────────
LOCK_TTL_MS=1800000

# ── API port ──────────────────────────────────────────────────────────────────
PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=3000

# ── WaitState TTL (секунды, дефолт 10 минут) ─────────────────────────────────
WAIT_STATE_TTL_SEC=600

# ── Stage 3: Spanish Jokes Auto ───────────────────────────────────────────────
JOKES_MIN_LENGTH=40
JOKES_MAX_LENGTH=600
JOKES_PAGES_PER_SOURCE=5
JOKES_SOURCES_ENABLED=
JOKES_FETCH_TIMEOUT_MS=10000

# Громкость фоновой музыки (дБ). Рекомендуется: от -25 до -12.
MUSIC_VOLUME_DB=-18

# ── Encryption (AES-256-GCM для YouTube refresh tokens) ───────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_chars_key_here

# ── Библиотеки в MinIO ─────────────────────────────────────────────────────────
# Фоновые видео:  s3://renderer/library/backgrounds/*.mp4
# Фоновая музыка: s3://renderer/library/music/*.mp3
# Загрузить через бота: /library → «Загрузить видео/музыку»

# ── Управление библиотеками ───────────────────────────────────────────────────
# Telegram user ID администраторов через запятую
ADMIN_TELEGRAM_USER_IDS=123456789

# ── YouTube OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Requires YouTube Data API v3 enabled
YOUTUBE_CLIENT_ID=your_google_client_id
YOUTUBE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
