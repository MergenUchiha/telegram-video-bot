# QUICK START
# 1. Copy this file to .env
# 2. Change these first:
#    - TELEGRAM_BOT_TOKEN
#    - AUTONOMY_OPS_CHAT_ID
#    - OPS_API_TOKEN
# 3. Only if you want automatic YouTube upload, also fill:
#    - YOUTUBE_CLIENT_ID
#    - YOUTUBE_CLIENT_SECRET
#    - YOUTUBE_REFRESH_TOKEN
#    - YOUTUBE_CHANNEL_ID
#    - YOUTUBE_CHANNEL_TITLE
#
# Docker note:
# docker-compose.yml now reads .env, not .env.example.

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
# polling (dev) или webhook (prod)
TELEGRAM_BOT_MODE=polling
# Только для webhook: секретный токен для проверки X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=change_me_to_random_string
# Только для webhook: публичный URL бота
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://renderer:renderer_secret@localhost:5432/renderer
POSTGRES_DB=renderer
POSTGRES_USER=renderer
POSTGRES_PASSWORD=renderer_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=0

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=renderer
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRES_SECONDS=1800

# ── Kokoro TTS ────────────────────────────────────────────────────────────────
KOKORO_BASE_URL=http://localhost:8880
KOKORO_API_PATH=/v1/audio/speech
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_heart
KOKORO_RESPONSE_FORMAT=wav
KOKORO_TIMEOUT_MS=120000

# ── Render worker ─────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Путь к шрифту для overlay comment (Linux: /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf)
FONT_PATH=C:\Windows\Fonts\arial.ttf
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
DEFAULT_DUCK_DB=-18
RENDER_TIMEOUT_MS=1200000
RENDER_TMP_DIR=/tmp/renderer

# ── Автоочистка (CleanupService) ──────────────────────────────────────────────
TMP_CLEANUP_AGE_HOURS=2
INPUT_LIFECYCLE_DAYS=3
OUTPUT_LIFECYCLE_DAYS=7

# ── Rate limiting (бот) ───────────────────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SEC=60

# ── Метрики ───────────────────────────────────────────────────────────────────
METRICS_TOKEN=change_me_to_random_string
OPS_API_TOKEN=change_me_to_random_string

# ── BullMQ ────────────────────────────────────────────────────────────────────
BULLMQ_PREFIX=tvb

# ── Redis lock TTL ────────────────────────────────────────────────────────────
LOCK_TTL_MS=1800000

# ── API port ──────────────────────────────────────────────────────────────────
PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=3000

# ── Stage 3: Spanish Jokes Auto ───────────────────────────────────────────────
# Мин. / макс. длина текста анекдота (символов)
JOKES_MIN_LENGTH=40
JOKES_MAX_LENGTH=600
JOKES_PAGES_PER_SOURCE=5         # страниц с каждого источника
JOKES_SOURCES_ENABLED="https://www.chistes.com/categoria/chistes-cortos/"          # пусто = все; или: "chistes.com,reir.es"

# Таймаут HTTP-запроса к источнику анекдотов (мс)
JOKES_FETCH_TIMEOUT_MS=10000

JOKES_CACHE_TTL_SEC=21600

# Громкость фоновой музыки в режиме Spanish Jokes Auto (дБ).
# Отрицательные значения — тише. Рекомендуется: от -25 до -12.
MUSIC_VOLUME_DB=-18

# Длительность авто-ролика в секундах, если фоновое видео зациклено.
# Используется когда фоновое видео короче нужного времени.
# (фактически видео обрезается по длине исходного фона, это резервный параметр)
AUTO_VIDEO_DURATION_SEC=45

# ── Autonomous Daily YouTube Shorts ───────────────────────────────────────────
AUTONOMY_ENABLED=false
AUTONOMY_OPS_CHAT_ID=
AUTONOMY_TIMEZONE=Asia/Ashgabat
AUTONOMY_WINDOW_START=09:00
AUTONOMY_WINDOW_END=21:00
AUTONOMY_DEFAULT_DAILY_COUNT=5
AUTONOMY_MAX_DAILY_COUNT=12

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_TITLE=
YOUTUBE_CATEGORY_ID=23
YOUTUBE_TITLE_SUFFIX=#shorts
YOUTUBE_DESCRIPTION_FOOTER=

# ── Структура библиотек в MinIO ────────────────────────────────────────────────
# Фоновые видео:  s3://renderer/library/backgrounds/*.mp4
# Фоновая музыка: s3://renderer/library/music/*.mp3
#
# Загрузить через MinIO Console: http://localhost:9001
# Или через mc:
#   mc alias set local http://localhost:9000 minioadmin minioadmin
#   mc cp ./video.mp4 local/renderer/library/backgrounds/
#   mc cp ./track.mp3 local/renderer/library/music/

# ── Управление библиотеками (LibraryAdminService) ─────────────────────────────
# Telegram user ID администраторов через запятую.
# Только эти пользователи могут использовать /library.
# Узнать свой ID: напиши боту @userinfobot
ADMIN_TELEGRAM_USER_IDS=123456789
