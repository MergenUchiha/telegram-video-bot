// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentMode {
  STANDARD
  SPANISH_JOKES_AUTO
}

enum RenderSessionState {
  WAIT_VIDEO
  WAIT_TEXT_OR_SETTINGS
  READY_TO_RENDER
  RENDER_QUEUED
  RENDERING
  RENDER_DONE
  RENDER_FAILED

  YOUTUBE_WAIT_CHANNEL
  YOUTUBE_UPLOADING
  YOUTUBE_DONE
  YOUTUBE_FAILED
}

enum SubtitlesMode {
  NONE
  HARD
  SOFT
}

enum OriginalAudioPolicy {
  REPLACE
  DUCK
  MUTE
  KEEP
}

enum RenderJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum YoutubeUploadStatus {
  QUEUED
  UPLOADING
  DONE
  FAILED
}

enum TriggerSource {
  MANUAL
  AUTONOMOUS
}

enum YoutubeVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum AutonomousDayPlanSource {
  DEFAULT
  OVERRIDE
}

enum AutonomousDayPlanStatus {
  PLANNED
  IN_PROGRESS
  DONE
  PARTIAL_FAILED
  FAILED
}

enum AutonomousRunState {
  PLANNED
  QUEUED
  RENDERING
  YOUTUBE_UPLOADING
  SUCCEEDED
  FAILED
  CANCELLED
}
